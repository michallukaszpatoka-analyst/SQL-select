select SalesOrderID, RevisionNumber, OrderDate, DueDate, ShipDate, Status, OnlineOrderFlag
from sales.SalesOrderHeader
where OrderDate between '2014-05-01 00:00:00.000' and '2014-05-30 23:59:59.000'
order by OrderDate

